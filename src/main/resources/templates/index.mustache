{{> layout/header}}

<div style="
    background: linear-gradient(160deg, #0a0a0a 0%, #111 50%, #0d0d0d 100%);
    border-bottom: 1px solid #1e1e1e;
    padding: 5rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
">
    <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:repeating-linear-gradient(0deg,transparent,transparent 40px,rgba(232,255,0,0.015) 40px,rgba(232,255,0,0.015) 41px);pointer-events:none;"></div>
    <p style="color:#e8ff00;font-size:0.78rem;letter-spacing:4px;text-transform:uppercase;margin-bottom:1.2rem;">💪 운동하는 개발자의 기록</p>
    <h1 style="font-family:'Bebas Neue',sans-serif;font-size:5rem;letter-spacing:8px;color:#f0f0f0;line-height:1;margin-bottom:1rem;">
        IRON<span style="color:#e8ff00;">LOG</span>
    </h1>
    <p style="color:#888;font-size:1rem;max-width:480px;margin:0 auto 2.5rem;">
        헬스, 식단, 홈트, 보충제 — 몸을 만드는 모든 기록을 남기는 공간
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;">
        <a href="/board/list" style="background:#e8ff00;color:#000;font-weight:700;font-size:0.85rem;letter-spacing:2px;text-transform:uppercase;padding:0.8rem 2rem;border-radius:4px;transition:all 0.2s;">게시글 보기</a>
        <a href="/user/join-form" style="background:transparent;color:#888;font-size:0.85rem;letter-spacing:2px;text-transform:uppercase;padding:0.8rem 2rem;border-radius:4px;border:1px solid #2a2a2a;transition:all 0.2s;">시작하기</a>
    </div>
</div>

<div class="container">
    <!-- 카테고리 섹션 -->
    <div style="margin-bottom:3rem;">
        <p style="font-size:0.75rem;letter-spacing:3px;text-transform:uppercase;color:#555;margin-bottom:1.5rem;">카테고리</p>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;">
            <a href="/board/list?category=헬스" class="card" style="text-align:center;padding:1.5rem;text-decoration:none;">
                <div style="font-size:2rem;margin-bottom:0.5rem;">🏋️</div>
                <div style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:2px;color:#e8ff00;">헬스</div>
            </a>
            <a href="/board/list?category=식단" class="card" style="text-align:center;padding:1.5rem;text-decoration:none;">
                <div style="font-size:2rem;margin-bottom:0.5rem;">🥩</div>
                <div style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:2px;color:#e8ff00;">식단</div>
            </a>
            <a href="/board/list?category=홈트" class="card" style="text-align:center;padding:1.5rem;text-decoration:none;">
                <div style="font-size:2rem;margin-bottom:0.5rem;">🤸</div>
                <div style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:2px;color:#e8ff00;">홈트</div>
            </a>
            <a href="/board/list?category=보충제" class="card" style="text-align:center;padding:1.5rem;text-decoration:none;">
                <div style="font-size:2rem;margin-bottom:0.5rem;">💊</div>
                <div style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:2px;color:#e8ff00;">보충제</div>
            </a>
        </div>
    </div>

    <!-- 최신 게시글 -->
    <div>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
            <p style="font-size:0.75rem;letter-spacing:3px;text-transform:uppercase;color:#555;">최신 게시글</p>
            <a href="/board/list" style="font-size:0.78rem;color:#e8ff00;letter-spacing:1px;">전체보기 →</a>
        </div>
        {{#boards}}
            <a href="/board/{{id}}" style="display:block;text-decoration:none;margin-bottom:1rem;">
                <div class="card" style="display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <span class="badge" style="margin-bottom:0.4rem;">{{categoryName}}</span>
                        <h3 style="font-size:1rem;font-weight:500;color:#f0f0f0;margin-top:0.3rem;">{{title}}</h3>
                        <p style="font-size:0.8rem;color:#666;margin-top:0.3rem;">{{username}} · {{createdAt}}</p>
                    </div>
                    <span style="color:#444;font-size:1.2rem;">→</span>
                </div>
            </a>
        {{/boards}}
    </div>
</div>

{{> layout/footer}}
