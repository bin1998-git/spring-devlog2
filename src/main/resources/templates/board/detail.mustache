{{> layout/header}}

<div class="container" style="max-width:800px;">

    <!-- 게시글 헤더 -->
    <div style="margin-bottom:2rem;">
        <div style="margin-bottom:1rem;">
            <span class="badge">{{board.category.name}}</span>
        </div>
        <h1 style="font-family:'Bebas Neue',sans-serif;font-size:2.8rem;letter-spacing:3px;color:#f0f0f0;line-height:1.1;margin-bottom:1rem;">{{board.title}}</h1>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 0;border-top:1px solid #1e1e1e;border-bottom:1px solid #1e1e1e;">
            <div style="display:flex;align-items:center;gap:0.8rem;">
                <div style="width:36px;height:36px;background:#e8ff00;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;color:#000;font-size:0.9rem;">
                    {{board.user.username}}
                </div>
                <div>
                    <p style="font-size:0.88rem;font-weight:500;color:#ddd;">{{board.user.username}}</p>
                    <p style="font-size:0.78rem;color:#555;">{{board.time}}</p>
                </div>
            </div>
            {{#isOwner}}
            <div style="display:flex;gap:0.5rem;">
                <a href="/board/{{board.id}}/update-form" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid #2a2a2a;color:#888;">수정</a>
                <form action="/board/{{board.id}}/delete" method="post" style="margin:0;">
                    <button type="submit" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid rgba(255,77,0,0.3);color:#ff4d00;background:transparent;">삭제</button>
                </form>
            </div>
            {{/isOwner}}
        </div>
    </div>

    <!-- 본문 -->
    <div class="card" style="margin-bottom:3rem;line-height:1.9;font-size:0.97rem;color:#ccc;">
        {{board.content}}
    </div>

    <!-- 댓글 -->
    <div>
        <p style="font-size:0.75rem;letter-spacing:3px;text-transform:uppercase;color:#555;margin-bottom:1.5rem;">
            댓글 <span style="color:#e8ff00;">{{comments.size}}</span>
        </p>

        <!-- 댓글 작성 -->
        {{#session}}
        <form action="/comment/save" method="post" style="margin-bottom:2rem;">
            <input type="hidden" name="boardId" value="{{board.id}}">
            <div style="display:flex;gap:0.8rem;">
                <input type="text" name="content" placeholder="댓글을 입력하세요..." style="flex:1;background:#1a1a1a;border:1px solid #2a2a2a;border-radius:4px;color:#f0f0f0;font-family:inherit;font-size:0.9rem;padding:0.7rem 1rem;outline:none;">
                <button type="submit" style="background:#e8ff00;color:#000;font-weight:700;font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.7rem 1.4rem;border:none;border-radius:4px;white-space:nowrap;">등록</button>
            </div>
        </form>
        {{/session}}

        <!-- 댓글 목록 -->
        <div style="display:flex;flex-direction:column;gap:0.8rem;">
            {{#comments}}
                <div style="background:#111;border:1px solid #1e1e1e;border-radius:4px;padding:1rem 1.2rem;display:flex;justify-content:space-between;align-items:flex-start;">
                    <div>
                        <p style="font-size:0.82rem;font-weight:600;color:#e8ff00;margin-bottom:0.3rem;">{{user.username}}</p>
                        <p style="font-size:0.92rem;color:#ccc;">{{content}}</p>
                        <p style="font-size:0.75rem;color:#444;margin-top:0.4rem;">{{time}}</p>
                    </div>
                    {{#isOwner}}
                        <form action="/comment/{{id}}/delete" method="post" style="margin:0;">
                            <!-- boardId 히든 필드 - 삭제 후 리다이렉트할 게시글 번호 -->
                            <input type="hidden" name="boardId" value="{{board.id}}">
                            <button type="submit" style="background:transparent;border:none;color:#444;font-size:0.78rem;cursor:pointer;">삭제</button>
                        </form>
                    {{/isOwner}}
                </div>
            {{/comments}}

            {{^comments}}
            <div style="text-align:center;padding:2rem;color:#333;font-size:0.85rem;">
                아직 댓글이 없습니다. 첫 댓글을 남겨보세요!
            </div>
            {{/comments}}
        </div>
    </div>

    <div style="margin-top:2.5rem;">
        <a href="/board/list" style="font-size:0.82rem;color:#555;letter-spacing:1px;">← 목록으로</a>
    </div>
</div>

{{> layout/footer}}
