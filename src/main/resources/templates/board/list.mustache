{{> layout/header}}

<div class="container">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:2rem;">
        <div>
            <h1 class="page-title">BOARD</h1>
            <p class="page-subtitle">모든 운동 기록을 확인하세요</p>
        </div>
        {{#session}}
        <a href="/board/save-form" class="btn-accent" style="padding:0.6rem 1.4rem;border-radius:4px;font-size:0.82rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">+ 글쓰기</a>
        {{/session}}
    </div>

    <!-- 카테고리 필터 -->
    <div style="display:flex;gap:0.5rem;margin-bottom:2rem;flex-wrap:wrap;">
        <a href="/board/list" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid #e8ff00;color:#e8ff00;background:rgba(232,255,0,0.08);">전체</a>
        <a href="/board/list?category=헬스" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid #2a2a2a;color:#888;">헬스</a>
        <a href="/board/list?category=식단" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid #2a2a2a;color:#888;">식단</a>
        <a href="/board/list?category=홈트" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid #2a2a2a;color:#888;">홈트</a>
        <a href="/board/list?category=보충제" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid #2a2a2a;color:#888;">보충제</a>
    </div>

    <!-- 게시글 목록 -->
    <div style="display:flex;flex-direction:column;gap:1rem;">
        {{#boards}}
        <a href="/board/{{id}}" style="text-decoration:none;">
            <div class="card" style="display:flex;justify-content:space-between;align-items:center;gap:1rem;">
                <div style="flex:1;">
                    <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.5rem;">
                        <span class="badge">{{category.name}}</span>
                    </div>
                    <h2 style="font-size:1.05rem;font-weight:500;color:#f0f0f0;margin-bottom:0.4rem;">{{title}}</h2>
                    <p style="font-size:0.82rem;color:#555;">
                        <span style="color:#777;">{{user.username}}</span>
                        &nbsp;·&nbsp;
                        <span>{{time}}</span>
                    </p>
                </div>
                <span style="color:#333;font-size:1.5rem;flex-shrink:0;">→</span>
            </div>
        </a>
        {{/boards}}

        {{^boards}}
        <div style="text-align:center;padding:4rem;color:#444;">
            <p style="font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:3px;color:#2a2a2a;">NO POSTS YET</p>
            <p style="font-size:0.85rem;margin-top:0.5rem;">첫 번째 게시글을 작성해보세요!</p>
        </div>
        {{/boards}}
    </div>
</div>

{{> layout/footer}}
