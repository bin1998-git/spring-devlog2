{{> layout/header}}

<div class="container">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:2rem;">
        <div>
            <h1 class="page-title">BOARD</h1>
            <p class="page-subtitle">모든 운동 기록을 확인하세요</p>
        </div>
        {{#sessionUser}}
        <a href="/board/save-form" class="btn-accent" style="padding:0.6rem 1.4rem;border-radius:4px;font-size:0.82rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;">+ 글쓰기</a>
        {{/sessionUser}}
    </div>

    <!-- 카테고리 필터 -->
    <div style="display:flex;gap:0.5rem;margin-bottom:2rem;flex-wrap:wrap;">
        <a href="/board/list" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid {{#isAll}}#e8ff00{{/isAll}}{{^isAll}}#2a2a2a{{/isAll}};color:{{#isAll}}#e8ff00{{/isAll}}{{^isAll}}#888{{/isAll}};background:{{#isAll}}rgba(232,255,0,0.08){{/isAll}}{{^isAll}}transparent{{/isAll}};">전체</a>
        <a href="/board/list?category=헬스" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid {{#isHealth}}#e8ff00{{/isHealth}}{{^isHealth}}#2a2a2a{{/isHealth}};color:{{#isHealth}}#e8ff00{{/isHealth}}{{^isHealth}}#888{{/isHealth}};background:{{#isHealth}}rgba(232,255,0,0.08){{/isHealth}}{{^isHealth}}transparent{{/isHealth}};">헬스</a>
        <a href="/board/list?category=식단" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid {{#isDiet}}#e8ff00{{/isDiet}}{{^isDiet}}#2a2a2a{{/isDiet}};color:{{#isDiet}}#e8ff00{{/isDiet}}{{^isDiet}}#888{{/isDiet}};background:{{#isDiet}}rgba(232,255,0,0.08){{/isDiet}}{{^isDiet}}transparent{{/isDiet}};">식단</a>
        <a href="/board/list?category=홈트" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid {{#isHome}}#e8ff00{{/isHome}}{{^isHome}}#2a2a2a{{/isHome}};color:{{#isHome}}#e8ff00{{/isHome}}{{^isHome}}#888{{/isHome}};background:{{#isHome}}rgba(232,255,0,0.08){{/isHome}}{{^isHome}}transparent{{/isHome}};">홈트</a>
        <a href="/board/list?category=보충제" style="font-size:0.78rem;letter-spacing:1px;text-transform:uppercase;padding:0.4rem 1rem;border-radius:4px;border:1px solid {{#isSupplement}}#e8ff00{{/isSupplement}}{{^isSupplement}}#2a2a2a{{/isSupplement}};color:{{#isSupplement}}#e8ff00{{/isSupplement}}{{^isSupplement}}#888{{/isSupplement}};background:{{#isSupplement}}rgba(232,255,0,0.08){{/isSupplement}}{{^isSupplement}}transparent{{/isSupplement}};">보충제</a>
    </div>

    <div style="display:flex;flex-direction:column;gap:1rem;">
        {{#boardList}}
        <a href="/board/{{id}}" style="text-decoration:none;">
            <div class="card" style="display:flex;justify-content:space-between;align-items:center;gap:1rem;">
                <div style="flex:1;">
                    <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.5rem;">
                        <span class="badge">{{categoryName}}</span>
                    </div>
                    <h2 style="font-size:1.05rem;font-weight:500;color:#f0f0f0;margin-bottom:0.4rem;">{{title}}</h2>
                    <p style="font-size:0.82rem;color:#555;">
                        <span style="color:#777;">{{username}}</span>
                        &nbsp;·&nbsp;
                        <span>{{writeDate}}</span>
                    </p>
                </div>
                <span style="color:#333;font-size:1.5rem;flex-shrink:0;">→</span>
            </div>
        </a>
        {{/boardList}}

        {{^boardList}}
        <div style="text-align:center;padding:4rem;color:#444;">
            <p style="font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:3px;color:#2a2a2a;">NO POSTS YET</p>
            <p style="font-size:0.85rem;margin-top:0.5rem;">첫 번째 게시글을 작성해보세요!</p>
        </div>
        {{/boardList}}
    </div>
</div>

{{> layout/footer}}